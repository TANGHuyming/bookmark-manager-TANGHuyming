<!-- views/partials/header.handlebars -->
<header class="border-b border-gray-800 px-6 py-4">
  <div class="max-w-5xl mx-auto flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="text-lg font-bold tracking-widest text-white uppercase hover:text-blue-400 transition">
      🔖 Admin
    </a>

    <!-- Nav -->
    <nav class="flex items-center gap-6">
      <a href="/"
        class="text-sm text-gray-400 hover:text-white transition {{#if isHome}}text-white border-b border-blue-400{{/if}}">
        Dashboard
      </a>
      <a href="/bookmarks"
        class="text-sm text-gray-400 hover:text-white transition {{#if isBookmarks}}text-white border-b border-blue-400{{/if}}">
        All Bookmarks
      </a>
      <a href="/bookmarks/new"
        class="text-sm text-gray-400 hover:text-white transition {{#if isBookmarks}}text-white border-b border-blue-400{{/if}}">
        New Bookmarks
      </a>
      <a href="/login"
        class="text-sm text-gray-400 hover:text-white transition {{#if isBookmarks}}text-white border-b border-blue-400{{/if}}">
        Login
      </a>
      <a href="/logout"
        class="text-sm text-gray-400 hover:text-white transition {{#if isBookmarks}}text-white border-b border-blue-400{{/if}}">
        Logout
      </a>
    </nav>
  </div>
</header>