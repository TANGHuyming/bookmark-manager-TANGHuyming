<div
    class="bg-gray-900 border border-gray-800 rounded-lg px-5 py-4 flex items-center justify-between hover:border-gray-600 transition">
    <div class="flex items-center gap-4 min-w-0">
        <div class="w-2 h-2 rounded-full shrink-0 {{#if this.isArchived}}bg-gray-600{{else}}bg-green-400{{/if}}">
        </div>
        <div class="min-w-0">
            <div class="text-sm text-white font-medium truncate">{{this.title}}</div>
            <div class="text-xs text-gray-500 truncate">{{this.url}}</div>
        </div>
    </div>
    <div class="flex items-center gap-2 shrink-0 ml-4">
        <a href="{{this.url}}" target="_blank"
            class="text-xs text-gray-400 hover:text-white transition px-3 py-1.5 rounded border border-gray-700 hover:border-gray-500">
            Visit
        </a>
        <a href="/bookmarks/{{this.slug}}"
            class="text-xs text-gray-400 hover:text-white transition px-3 py-1.5 rounded border border-gray-700 hover:border-gray-500">
            View Details
        </a>
        {{#unless @root.isPublic}}
            <a href="/bookmarks/{{this.slug}}/edit"
                class="text-xs text-gray-400 hover:text-white transition px-3 py-1.5 rounded border border-gray-700 hover:border-gray-500">
                Edit
            </a>
            <form action="/bookmarks/{{this.slug}}/delete" method="POST">
                <button type="submit" class="cursor-pointer text-xs text-gray-400 hover:text-white transition px-3 py-1.5 rounded border border-gray-700 hover:border-gray-500">
                    Delete
                </button>
            </form>
            {{#if this.isArchived}}
                <form action="/bookmarks/{{this.slug}}/unarchive" method="POST">
                    <button type="submit" class="cursor-pointer text-xs text-gray-400 hover:text-white transition px-3 py-1.5 rounded border border-gray-700 hover:border-gray-500">
                        Unarchive
                    </button>
                </form>
            {{else}}
                <form action="/bookmarks/{{this.slug}}/archive" method="POST">
                    <button type="submit" class="cursor-pointer text-xs text-gray-400 hover:text-white transition px-3 py-1.5 rounded border border-gray-700 hover:border-gray-500">
                        Archive
                    </button>
                </form>
            {{/if}}
        {{/unless}}
    </div>
</div>