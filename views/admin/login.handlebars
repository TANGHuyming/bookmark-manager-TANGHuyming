<style>
  th {
    border: 1px solid #1F2937;
    padding: 4px;
  }

  td {
    border: 1px solid #1F2937;
    padding: 4px;
  }
</style>

<main class="max-w-5xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight text-white mb-1">Admin Login</h1>
      <p class="text-gray-500 text-sm mb-5">Sign in with your admin username and password.</p>
      
      {{#if isError}}
      <div class="text-red-500 text-sm mb-5">{{error}}</div>
      {{/if}}
      
      <form method="POST" action="/login"
        class="bg-gray-900 border border-gray-800 rounded-lg px-6 py-16 gap-y-5 grid grid-cols-[20%_1fr]"
      >
        <label for="username">Username</label>
        <input id="username" name="username" type="text" class="border-gray-500 border p-2" placeholder="Enter username"
          autocomplete="username" required>
        <label for="password">Password</label>
        <input id="password" name="password" type="password" class="border-gray-500 border p-2" placeholder="Enter password"
          autocomplete="current-password" required>
        <button type="submit" class="col-span-2 border border-gray-700 bg-gray-800 hover:bg-gray-700 hover:border-gray-600 ease-in-out transition duration-300 cursor-pointer rounded-lg p-2">Sign in</button>
      </form>
    </div>

    <div class="mb-10">
      <h2 class="text-3xl font-bold tracking-tight text-white mb-1">Seeded Demo Users</h2>
      <p class="text-gray-500 text-sm mb-5">Use any account below to sign in.</p>
      <table class="w-1/2 mx-auto bg-gray-900 border border-gray-800 rounded-lg">
        <thead>
          <tr>
            <th>Name</th>
            <th>Username</th>
            <th>Password</th>
          </tr>
        </thead>
        <tbody>
          {{#each demoUsers}}
          <tr>
            <td>{{this.name}}</td>
            <td><code>{{this.username}}</code></td>
            <td><code>{{this.password}}</code></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
</main>