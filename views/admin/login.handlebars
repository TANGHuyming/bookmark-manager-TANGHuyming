<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body admin-login-body">
  <main class="admin-login-wrap">
    <section class="admin-login-card">
      <h1>Admin Login</h1>
      <p class="admin-note">Sign in with your admin username and password.</p>

      {{#if error}}
        <div class="admin-alert admin-alert--error">{{error}}</div>
      {{/if}}

      <form method="POST" action="/login" class="admin-form">
        <div class="form-group">
          <label for="username">Username</label>
          <input
            id="username"
            name="username"
            type="text"
            class="form-input"
            placeholder="Enter username"
            autocomplete="username"
            required
          >
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-input"
            placeholder="Enter password"
            autocomplete="current-password"
            required
          >
        </div>

        <div class="form-actions">
          <button type="submit" class="btn">Sign in</button>
          <a class="btn btn--outline" href="http://localhost:3000">Back to blog</a>
        </div>
      </form>

      {{#if demoUsers}}
        <section class="admin-seeder" aria-label="Seeded demo admin users">
          <h2>Seeded Demo Users</h2>
          <p class="admin-note">Use any account below to sign in.</p>
          <div class="admin-seeder-table-wrap">
            <table class="admin-seeder-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Username</th>
                  <th>Password</th>
                </tr>
              </thead>
              <tbody>
                {{#each demoUsers}}
                  <tr>
                    <td>{{this.name}}</td>
                    <td><code>{{this.username}}</code></td>
                    <td><code>{{this.password}}</code></td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </section>
      {{/if}}
    </section>
  </main>
</body>
</html>