{{!--
  FILE: views/admin/edit.handlebars
  PURPOSE: Shared form view for creating and editing posts.

  Context:
    isNew  – true when creating a new post
    post   – null when isNew, populated post object when editing
    slugExample – example slug string (shown on new post form)

  TEACHING NOTE:
    Using one view for both "new" and "edit" is the DRY principle applied
    to templates. The `isNew` flag controls which heading and helper text
    to display. The form `action` attribute would differ in a real app.
--}}
<div class="admin-form-wrapper">

  {{#if isNew}}
    <h2>Create New Post</h2>
    <p>Fill in the fields below. The slug will be auto-generated from the title.</p>
    <p class="admin-note">
      Example slug: <code>{{slugExample}}</code>
      &mdash; generated by <code>utils/slugify.js</code>
    </p>
  {{else}}
    <h2>Editing: {{post.title}}</h2>
    <p>
      Public URL:
      <a href="http://localhost:3000/posts/{{post.slug}}" target="_blank">
        /posts/{{post.slug}}
      </a>
    </p>
  {{/if}}

  {{!--
    TEACHING: In a real app this form would POST to a handler that validates
    input, updates the data store, and redirects. Here it is read-only to keep
    the focus on routing and middleware, not form processing.
  --}}
  <form
    class="admin-form"
    action="{{#if isNew}}/posts/new{{else}}/posts/{{post.slug}}/edit{{/if}}"
    method="POST"
  >

    <div class="form-group">
      <label for="title">Title</label>
      <input
        type="text"
        id="title"
        name="title"
        class="form-input"
        value="{{#unless isNew}}{{post.title}}{{/unless}}"
        placeholder="Post title"
        required
      >
    </div>

    <div class="form-group">
      <label for="slug">Slug (URL segment)</label>
      <input
        type="text"
        id="slug"
        name="slug"
        class="form-input"
        value="{{#unless isNew}}{{post.slug}}{{/unless}}"
        placeholder="auto-generated-from-title"
        pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$"
        title="Lowercase letters and hyphens only"
      >
    </div>

    <div class="form-group">
      <label for="category">Category</label>
      <input
        type="text"
        id="category"
        name="category"
        class="form-input"
        value="{{#unless isNew}}{{post.category}}{{/unless}}"
        placeholder="e.g. Node.js"
      >
    </div>

    <div class="form-group">
      <label for="content">Content</label>
      <textarea
        id="content"
        name="content"
        class="form-textarea"
        rows="10"
        placeholder="Write your post here…"
      >{{#unless isNew}}{{post.content}}{{/unless}}</textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn">
        {{#if isNew}}Create Post{{else}}Save Changes{{/if}}
      </button>
      <a href="/posts" class="btn btn--outline">Cancel</a>
    </div>

  </form>
</div>
