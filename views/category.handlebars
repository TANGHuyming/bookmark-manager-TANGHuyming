{{!--
  FILE: views/category.handlebars
  PURPOSE: Archive page listing all posts in a given category.

  SEO NOTE:
    /category/express gives search engines a clear, hierarchical URL.
    The <h1> reinforces the keyword that matches the URL segment.
--}}
<h1>Category: {{categoryName}}</h1>

<p class="post-count">{{posts.length}} posts in this category</p>

<div class="post-list">
  {{#each posts}}
    <article class="post-card">
      <h2 class="post-card__title">
        <a href="/posts/{{this.slug}}">{{this.title}}</a>
      </h2>
      <p class="post-card__meta">
        <time datetime="{{this.date}}">{{formatDate this.date}}</time>
      </p>
      <p class="post-card__excerpt">{{this.excerpt}}</p>
    </article>
  {{else}}
    <p>No posts found in this category.</p>
  {{/each}}
</div>

<a href="/posts" class="btn btn--outline">&larr; All Posts</a>
