{{!--
  FILE: views/index.handlebars
  PURPOSE: Home page – shows the 3 most recent posts.

  TEACHING NOTE:
    {{#each posts}} iterates over the `posts` array passed by blogController.home.
    {{this.title}}, {{this.slug}}, etc. access properties on each item.
    {{else}} renders when the array is empty.
--}}
<section class="hero">
  <h1>Welcome to My Blog</h1>
  <p>Thoughts on Node.js, Express, and modern web development.</p>
</section>

<section class="post-grid">
  <h2>Recent Posts</h2>

  {{#each posts}}
    <article class="post-card">
      <h3 class="post-card__title">
        {{!-- SEO NOTE: The link text and URL slug both contain keywords --}}
        <a href="/posts/{{this.slug}}">{{this.title}}</a>
      </h3>
      <p class="post-card__meta">
        <time datetime="{{this.date}}">{{formatDate this.date}}</time>
        &mdash;
        <a href="/category/{{this.categorySlug}}">{{this.category}}</a>
      </p>
      <p class="post-card__excerpt">{{this.excerpt}}</p>
      <a href="/posts/{{this.slug}}" class="btn">Read more &rarr;</a>
    </article>
  {{else}}
    <p>No posts yet. Check back soon!</p>
  {{/each}}

  <a href="/posts" class="btn btn--outline">View all posts &rarr;</a>
</section>
