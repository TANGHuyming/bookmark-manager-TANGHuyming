<main class="max-w-5xl mx-auto px-6 py-12">
    <!-- Header -->
    <div class="mb-10">
        <h1 class="text-4xl font-bold tracking-tight text-white mb-1">Search Result: {{q}}</h1>
    </div>

    {{#each filteredBookmarks}}
    <div class="bg-gray-900 border border-gray-800 rounded-lg px-5 py-4 flex items-center justify-between hover:border-gray-600 transition">
        <div class="flex items-center gap-4 min-w-0">
            <div class="w-2 h-2 rounded-full shrink-0 {{#if this.isArchived}}bg-gray-600{{else}}bg-green-400{{/if}}">
            </div>
            <div class="min-w-0">
                <div class="text-sm text-white font-medium truncate">{{this.title}}</div>
                <div class="text-xs text-gray-500 truncate">{{this.url}}</div>
            </div>
        </div>
        <div class="flex items-center gap-2 shrink-0 ml-4">
            <a href="{{this.url}}" target="_blank"
                class="text-xs text-gray-400 hover:text-white transition px-3 py-1.5 rounded border border-gray-700 hover:border-gray-500">
                Visit
            </a>
            <a href="/bookmarks/{{this.slug}}"
                class="text-xs text-gray-400 hover:text-white transition px-3 py-1.5 rounded border border-gray-700 hover:border-gray-500">
                View Details
            </a>
        </div>
    </div>
    {{/each}}
</main>