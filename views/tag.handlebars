{{!--
  FILE: views/tag.handlebars
  PURPOSE: Archive page listing all posts with a given tag.

  SEO NOTE:
    /tag/express is a flat taxonomy URL — easy to share, bookmark, and link.
    Tags provide a second orthogonal navigation axis (alongside categories).
--}}
<h1>Tag: <span class="tag tag--large">{{tagSlug}}</span></h1>

<p class="post-count">{{posts.length}} posts tagged "{{tagSlug}}"</p>

<div class="post-list">
  {{#each posts}}
    <article class="post-card">
      <h2 class="post-card__title">
        <a href="/posts/{{this.slug}}">{{this.title}}</a>
      </h2>
      <p class="post-card__meta">
        <time datetime="{{this.date}}">{{formatDate this.date}}</time>
        &mdash;
        <a href="/category/{{this.categorySlug}}">{{this.category}}</a>
      </p>
      <p class="post-card__excerpt">{{this.excerpt}}</p>
    </article>
  {{else}}
    <p>No posts found for this tag.</p>
  {{/each}}
</div>

<a href="/posts" class="btn btn--outline">&larr; All Posts</a>
