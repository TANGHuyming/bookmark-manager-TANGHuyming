<main class="max-w-5xl mx-auto px-6 py-12">
    <!-- Header -->
    <div class="mb-10">
        <h1 class="text-4xl font-bold tracking-tight text-white mb-1">{{title}}</h1>
        <p class="text-gray-500 text-sm">Details of this bookmark</p>
    </div>

    <div class="mb-10 bg-gray-900 border border-gray-800 rounded-lg px-5 py-4 flex flex-col items-center justify-between">

        <a href="{{url}}" target="_blank" class="text-gray-500 text-md">{{url}}</a>
        <p class="text-gray-500 text-md"><strong>Description</strong>: {{description}}</p>
        <p class="text-gray-500 text-md"><strong>Created At</strong>: {{createdAt}}</p>
        <p class="text-gray-500 text-md"><strong>Updated At</strong>: {{updatedAt}}</p>
        <div class="flex flex-row justify-center items-center gap-x-5">
            <p class="text-gray-500 text-sm"><strong>Tags</strong>: </p>
            {{#each tags}}
                <p class="text-gray-500 text-sm">{{this}}</p>
            {{/each}}
        </div>
    </div>
</main>