{{!--
  FILE: views/posts/detail.handlebars
  PURPOSE: Display a single blog post.

  Context provided by blogController.showPost:
    post.title, post.slug, post.content, post.date, post.author,
    post.category, post.categorySlug, post.tags[], related[]
--}}
<article class="post-detail">

  <header class="post-detail__header">
    <h1 class="post-detail__title">{{post.title}}</h1>
    <p class="post-detail__meta">
      By <strong>{{post.author}}</strong>
      &mdash;
      <time datetime="{{post.date}}">{{formatDate post.date}}</time>
      &mdash;
      Category: <a href="/category/{{post.categorySlug}}">{{post.category}}</a>
    </p>
    <p class="post-detail__tags">
      {{#each post.tags}}
        <a href="/tag/{{this}}" class="tag">{{this}}</a>
      {{/each}}
    </p>
  </header>

  <div class="post-detail__body">
    {{!--
      NOTE: post.content is plain text in this demo.
      In a real app you would use a Markdown renderer and triple-brace: {{{html}}}
      only after sanitising the output to prevent XSS.
    --}}
    {{#each (splitLines post.content)}}
      <p>{{this}}</p>
    {{/each}}
  </div>

  <hr>

  <nav class="post-detail__actions">
    <a href="/posts" class="btn btn--outline">&larr; All Posts</a>
  </nav>

</article>

{{#if related.length}}
  <section class="related-posts">
    <h2>More in {{post.category}}</h2>
    <ul>
      {{#each related}}
        <li><a href="/posts/{{this.slug}}">{{this.title}}</a></li>
      {{/each}}
    </ul>
  </section>
{{/if}}
