{{!--
  FILE: views/layouts/public.handlebars
  PURPOSE: Shared wrapper for all public-facing pages.

  TEACHING NOTE:
    {{{body}}} (triple braces) is where the child template is injected.
    Triple braces output unescaped HTML – needed here because body itself
    is a rendered HTML fragment. Never use triple braces for user input.

    Partials ({{> header}}) are reusable fragments loaded from views/partials/.
--}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {{!-- SEO NOTE: Descriptive, page-specific titles help search ranking --}}
  <title>{{pageTitle}} | My Blog</title>

  <meta name="description" content="A personal blog about Node.js, Express, and web development.">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  {{> header}}

  <main class="container">
    {{{body}}}
  </main>

  {{> footer}}

</body>
</html>
