<section class="max-w-5xl mx-auto px-6 py-12">
  <div class="text-4xl font-bold tracking-tight text-white mb-1">404</div>
  <h1 class="text-3xl font-bold tracking-tight text-white mb-1">Page Not Found</h1>
  <p class="text-gray-500 text-sm mb-5">
    {{#if message}}
      {{message}}
    {{else}}
      The page you are looking for does not exist or has been moved.
    {{/if}}
  </p>
  <a href="/" class="btn">Go home &rarr;</a>
</section>
